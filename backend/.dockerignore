# Never copy these into the Docker build context.

# Version control
.git
.gitignore
.gitattributes

# Dependencies (installed fresh inside the image)
node_modules
.pnp
.pnp.js

# Build output (compiled fresh inside the image)
dist
build
*.tsbuildinfo

# Secrets — rebuilt images must never contain local env files
.env
.env.*
!.env.example

# Tests + dev-only artifacts
__tests__
coverage
.nyc_output
*.spec.ts
*.test.ts

# Migrations + scripts not needed in runtime image
migrations/inventory-sync/dump
scripts/check-*
scripts/find-*
scripts/verify-*
scripts/test-*
scripts/smoke-*

# IDE / OS
.vscode
.idea
.DS_Store
*.swp
Thumbs.db

# Logs + runtime
npm-debug.log*
yarn-debug.log*
*.log
pids
*.pid

# Docs & graphify artifacts
docs
graphify-out
wiki
raw

# Docker itself
Dockerfile
.dockerignore

# CI / GitHub
.github
