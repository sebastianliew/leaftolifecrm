# Copy to /opt/l2l-backend/.env on the VPS and fill in real values.
# Never commit the populated .env.

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/l2l?retryWrites=true&w=majority

# Auth / sessions
JWT_SECRET=replace-with-strong-random-64-chars
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=replace-with-different-strong-random
REFRESH_TOKEN_EXPIRES_IN=30d
NEXTAUTH_SECRET=replace-with-strong-random

# CORS / frontend
FRONTEND_URL=https://crm.leaftolife.com.sg

# Admin bootstrap (leave unset unless provisioning)
ALLOW_ADMIN_CREATION=

# Email (SMTP) — fill if email features are used
EMAIL_ENABLED=false
EMAIL_FROM=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_PASSWORD=
EMAIL_CC=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=

# Fluent Forms webhook
FLUENT_FORMS_SECRET_KEY=
